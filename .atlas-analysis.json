  "keyFeatures": [
    "Real-time dashboard with appointment overview and statistics",
    "Comprehensive patient clinical record management with search and filtering",
    "Therapist profile and specialization management",
    "Interactive appointment scheduling with availability checking",
    "Treatment plan creation with session tracking and frequency management",
    "Visual calendar for managing therapist availability and schedules",
    "PDF report generation for patient clinical history",
    "Document upload and viewing for patient records",
    "Role-based authentication and private routes",
    "Responsive design optimized for desktop, tablet, and mobile devices"
  ],
  "publicApiSurface": [
    "/login - User authentication page",
    "/principal - Main dashboard with statistics and upcoming appointments",
    "/pacientes - Patient listing and search",
    "/pacientes/nuevo - Create new patient form",
    "/pacientes/historial/:pacienteId - Patient clinical history and records",
    "/terapeutas - Therapist management and listing",
    "/terapeutas/nuevo - Create new therapist form",
    "/agenda - Therapist availability and schedule management",
    "/citas - Appointment creation and scheduling",
    "/planes - Treatment plan creation and configuration",
    "/reportes - Analytics and charts dashboard",
    "/uploadfile - Document upload for patient records",
    "apiFetch() - Centralized API fetch helper with JWT authentication",
    "apiJson() - JSON API helper with error handling",
    "getToken() - Retrieve stored authentication token",
    "setToken() - Store authentication token",
    "clearSession() - Remove authentication token and clear session"
  ]
}
